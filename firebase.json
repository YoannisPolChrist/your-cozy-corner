{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/contact",
        "function": {
          "functionId": "contact",
          "region": "europe-west1"
        }
      },
      {
        "source": "/de/anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/en/anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/fr/anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/Prozessbegleitung",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/Prozessbegleitung/**",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/de/Prozessbegleitung",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/de/Prozessbegleitung/**",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/en/Prozessbegleitung",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/en/Prozessbegleitung/**",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/fr/Prozessbegleitung",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/fr/Prozessbegleitung/**",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
