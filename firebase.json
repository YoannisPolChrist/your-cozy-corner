{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/Prozessbegleitung",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/Prozessbegleitung/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/Prozessbegleitung/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/de",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/de/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/en",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/en/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/fr",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      },
      {
        "source": "/fr/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/contact",
        "function": {
          "functionId": "contact",
          "region": "europe-west1"
        }
      },
      {
        "source": "/de/anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/de/Anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/de/Anamnese/**",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/en/anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/en/Anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/en/Anamnese/**",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/fr/anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/fr/Anamnese",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/fr/Anamnese/**",
        "destination": "/Anamnese/index.html"
      },
      {
        "source": "/Prozessbegleitung",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/Prozessbegleitung/**",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/de/Prozessbegleitung",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/de/Prozessbegleitung/**",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/en/Prozessbegleitung",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/en/Prozessbegleitung/**",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/fr/Prozessbegleitung",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "/fr/Prozessbegleitung/**",
        "destination": "/Prozessbegleitung/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
